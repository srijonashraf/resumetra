#######################################
# Server Configuration
#######################################

# Server Port
PORT=7000

#######################################
# Google Gemini AI API Key
#######################################
GEMINI_API_KEY=your_gemini_api_key_here

#######################################
# PostgreSQL Database (cloud-hosted)
#######################################

# Generic Postgres connection string, e.g.:
# - Render / Railway / Neon / RDS:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@host:5432/resume_radar

# SSL options for cloud providers:
# - DB_SSL=false (default): let driver/provider decide SSL mode
# - DB_SSL=true           : force SSL
#   - DB_SSL_REJECT_UNAUTHORIZED=false (default): accept provided certs
#   - DB_SSL_REJECT_UNAUTHORIZED=true          : require trusted CA
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

#######################################
# Auth / Security
#######################################

# Used to sign application JWTs issued after Google login
JWT_SECRET=change_me_to_a_strong_random_secret

# JWT expiration time (e.g. "7d" for 7 days, "24h" for 24 hours)
JWT_EXPIRATION=7d

# Expected Google OAuth client ID (used to verify Google ID tokens)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
